# 정적 배포 빌드: NEXT_PUBLIC_* 값은 브라우저에 노출됩니다.
# 운영 API 키나 민감정보를 넣지 마세요.
# 공공 API 키가 필요한 경우 GitHub Actions, 서버리스 함수, 내부망 API 서버 등에서
# JSON으로 변환한 뒤 정적 사이트가 해당 JSON만 읽도록 구성하세요.

# 기상청 API허브: 운영키는 NEXT_PUBLIC_로 노출하지 말고 변환 JSON 생성 작업에서만 사용하세요.
KMA_APIHUB_AUTH_KEY=
KMA_APIHUB_SURFACE_OBS_URL=https://apihub.kma.go.kr/api/typ01/url/kma_sfctm2.php
KMA_APIHUB_MARINE_OBS_URL=https://apihub.kma.go.kr/api/typ03/url/sea_obs.php
KMA_APIHUB_FORECAST_URL=https://apihub.kma.go.kr/api/typ02/openApi/VilageFcstInfoService_2.0
KMA_APIHUB_AVIATION_OBS_URL=https://apihub.kma.go.kr/api/typ06/url/kma_amos.php

# 공공데이터포털/기상청: 해양기상관측자료 + 기상특보 대체 연동 후보
NEXT_PUBLIC_KMA_SERVICE_KEY=
NEXT_PUBLIC_KMA_OCEAN_API_URL=https://apis.data.go.kr/1360000/OceanInfoService/getWhBuoy
NEXT_PUBLIC_KMA_WARNING_API_URL=https://apis.data.go.kr/1360000/WthrWrnInfoService/getWthrWrnList

# 국립해양조사원: 조석예보 + 조류예보
NEXT_PUBLIC_KHOA_SERVICE_KEY=
NEXT_PUBLIC_KHOA_TIDE_API_URL=https://www.khoa.go.kr/api/oceangrid/tideObsPreTab/search.do
NEXT_PUBLIC_KHOA_CURRENT_API_URL=https://www.khoa.go.kr/api/oceangrid/fcTidalCurrent/search.do

# 국립수산과학원: 실시간 수온/해양환경 보조 검증
NEXT_PUBLIC_NIFS_SERVICE_KEY=
NEXT_PUBLIC_NIFS_RISA_API_URL=https://www.nifs.go.kr/OpenAPI_json

# 한국천문연구원: 일출/일몰/월출/월몰 출몰시각
NEXT_PUBLIC_KASI_SERVICE_KEY=
NEXT_PUBLIC_KASI_RISE_SET_API_URL=https://apis.data.go.kr/B090041/openapi/service/RiseSetInfoService/getAreaRiseSetInfo

# 육상/항공 API 연동 후보: 기상청 API허브 지상관측, 해양관측, 예특보, 항공기상,
# 에어코리아 PM10/PM2.5/오존, 산림청 산불위험예보.
# 정적 배포 환경에서는 운영키를 직접 노출하지 말고 변환된 JSON만 읽도록 구성하세요.

# 윈디 지도는 키 없는 임베드 화면을 사용합니다.
# 윈디 지점 예보: 공개 데모키 환경에서만 시간별 풍향/풍속/파고/파향/파주기 우선 반영
NEXT_PUBLIC_WINDY_POINT_FORECAST_KEY=
