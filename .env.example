# 정적 배포 빌드: NEXT_PUBLIC_* 값은 브라우저에 노출됩니다.
# 운영 API 키나 민감정보는 절대 NEXT_PUBLIC_* 이름으로 넣지 마세요.
# 브라우저용 지도키는 저장소 코드에 쓰지 말고 GitHub Secrets에서 빌드 때만 주입하세요.
NEXT_PUBLIC_VWORLD_API_KEY=

# GitHub Actions 또는 내부 변환 서버에서만 사용하는 값입니다.
# 정적 사이트는 public/data/weather-cache.json 같은 변환 JSON만 읽습니다.
WEATHER_CACHE_SOURCE_URL=
WEATHER_CACHE_SOURCE_TOKEN=

# 공공 API 연동 후보: GitHub Secrets 또는 내부망 서버 환경변수로만 설정하세요.
PUBLIC_DATA_SERVICE_KEY=
KMA_APIHUB_AUTH_KEY=
KMA_SERVICE_KEY=
KMA_ASOS_SERVICE_KEY=
KHOA_SERVICE_KEY=
KHOA_CURRENT_SERVICE_KEY=
KHOA_TIDE_RECENT_SERVICE_KEY=
KHOA_WATER_TEMP_SERVICE_KEY=
KASI_SERVICE_KEY=
NIFS_SERVICE_KEY=
AIRKOREA_SERVICE_KEY=
FOREST_SERVICE_KEY=
KMA_ROAD_WEATHER_SERVICE_KEY=
KMA_WIND_PROFILER_SERVICE_KEY=
KMA_AVIATION_SERVICE_KEY=
KMA_RADAR_SERVICE_KEY=
KMA_LIFE_INDEX_SERVICE_KEY=
KMA_TYPHOON_SERVICE_KEY=
KMA_IMPACT_FORECAST_SERVICE_KEY=
KMA_GTS_SERVICE_KEY=
KMA_LIGHTNING_SERVICE_KEY=
KMA_SATELLITE_SERVICE_KEY=
KMA_UPPER_AIR_SERVICE_KEY=
KMA_BEACH_WEATHER_SERVICE_KEY=

# 국립해양조사원 조석 관측소 코드는 운용 지점에 맞게 Secret으로 지정하세요.
KHOA_TIDE_OBS_CODE_SEOSAN=
KHOA_TIDE_OBS_CODE_DANGJIN=
KHOA_TIDE_OBS_CODE_TAEAN=
KHOA_TIDE_OBS_CODE_BORYEONG=
KHOA_CURRENT_OBS_CODE_SEOSAN=
KHOA_CURRENT_OBS_CODE_DANGJIN=
KHOA_CURRENT_OBS_CODE_TAEAN=
KHOA_CURRENT_OBS_CODE_BORYEONG=
KHOA_TEMP_OBS_CODE_SEOSAN=
KHOA_TEMP_OBS_CODE_DANGJIN=
KHOA_TEMP_OBS_CODE_TAEAN=
KHOA_TEMP_OBS_CODE_BORYEONG=

# 참고 URL 후보
KMA_APIHUB_BASE_URL=https://apihub.kma.go.kr
KMA_WEATHER_MAP_URL=https://www.weather.go.kr/wgis-nuri/html/map.html
KMA_MARINE_MAP_URL=https://marine.kma.go.kr/mmis/?menuId=sig_wh
KHOA_TIDE_API_URL=https://www.khoa.go.kr/api/oceangrid/tideObsPreTab/search.do
KHOA_CURRENT_API_URL=https://www.khoa.go.kr/api/oceangrid/fcTidalCurrent/search.do
KASI_RISE_SET_API_URL=https://apis.data.go.kr/B090041/openapi/service/RiseSetInfoService/getAreaRiseSetInfo

# 윈디 지도는 현재 키 없는 임베드 화면을 사용합니다.
