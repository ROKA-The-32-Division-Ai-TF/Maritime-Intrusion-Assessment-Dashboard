# 정적 배포 빌드: NEXT_PUBLIC_* 값은 브라우저에 노출됩니다.
# 운영 API 키나 민감정보는 절대 NEXT_PUBLIC_* 이름으로 넣지 마세요.

# GitHub Actions 또는 내부 변환 서버에서만 사용하는 값입니다.
# 정적 사이트는 public/data/weather-cache.json 같은 변환 JSON만 읽습니다.
WEATHER_CACHE_SOURCE_URL=
WEATHER_CACHE_SOURCE_TOKEN=

# 공공 API 연동 후보: GitHub Secrets 또는 내부망 서버 환경변수로만 설정하세요.
KMA_APIHUB_AUTH_KEY=
KMA_SERVICE_KEY=
KHOA_SERVICE_KEY=
KASI_SERVICE_KEY=
NIFS_SERVICE_KEY=
AIRKOREA_SERVICE_KEY=
FOREST_SERVICE_KEY=

# 참고 URL 후보
KMA_APIHUB_BASE_URL=https://apihub.kma.go.kr
KMA_WEATHER_MAP_URL=https://www.weather.go.kr/wgis-nuri/html/map.html
KMA_MARINE_MAP_URL=https://marine.kma.go.kr/mmis/?menuId=sig_wh
KHOA_TIDE_API_URL=https://www.khoa.go.kr/api/oceangrid/tideObsPreTab/search.do
KHOA_CURRENT_API_URL=https://www.khoa.go.kr/api/oceangrid/fcTidalCurrent/search.do
KASI_RISE_SET_API_URL=https://apis.data.go.kr/B090041/openapi/service/RiseSetInfoService/getAreaRiseSetInfo

# 윈디 지도는 현재 키 없는 임베드 화면을 사용합니다.
